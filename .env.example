# PostgreSQL connection string (Neon, Supabase, Railway, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (https://dashboard.stripe.com/apikeys)
# Use test keys (sk_test_..., pk_test_...) during development.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# PayPal (https://developer.paypal.com)
# Use sandbox client ID/secret first.
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# "sandbox" or "live"
PAYPAL_ENV="sandbox"

# MyFatoorah (https://myfatoorah.com) - regional gateway for the Middle East
# Get your API key from the MyFatoorah portal (Profile → API Keys).
# BASE_URL examples:
#   Sandbox (test):       https://apitest.myfatoorah.com
#   Live - Kuwait:        https://api.myfatoorah.com
#   Live - Jordan:        https://api-jo.myfatoorah.com
#   Live - Saudi Arabia:  https://api-sa.myfatoorah.com
#   Live - UAE:           https://api-ae.myfatoorah.com
#   Live - Egypt:         https://api-eg.myfatoorah.com
MYFATOORAH_API_KEY=""
MYFATOORAH_BASE_URL="https://apitest.myfatoorah.com"

# Optional: SMTP for password reset emails (placeholder, console fallback used in dev)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"
