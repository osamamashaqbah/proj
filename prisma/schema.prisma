generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- AUTH / USERS -----------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  locale        String    @default("en") // "en" | "ar"
  isBanned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  roles             UserRole[]
  listings          Listing[]
  ordersAsBuyer     Order[]            @relation("BuyerOrders")
  guaranteeRequests GuaranteeRequest[]
  reviewsAuthored   Review[]           @relation("ReviewAuthor")
  reviewsReceived   Review[]           @relation("ReviewTarget")
  ticketsOpened     SupportTicket[]    @relation("TicketAuthor")
  ticketsAssigned   SupportTicket[]    @relation("TicketAssignee")
  ticketMessages    SupportTicketMessage[]
  passwordResets    PasswordResetToken[]
  auditLogs         AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------------- RBAC -----------------------------

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // ADMIN | EMPLOYEE | USER (and custom)
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "listing.approve"
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ----------------------------- MARKETPLACE -----------------------------

enum CategoryKind {
  USED_GAMES
  ACCOUNTS
  SUBSCRIPTIONS
  DIGITAL_ITEMS
  SERVICES
  OTHER
}

model Category {
  id          String        @id @default(cuid())
  slug        String        @unique
  nameEn      String
  nameAr      String
  kind        CategoryKind  @default(OTHER)
  enabled     Boolean       @default(true)
  // High-risk categories (accounts/subs/digital) display compliance warnings
  riskWarning Boolean       @default(false)
  createdAt   DateTime      @default(now())
  listings    Listing[]
  storeProducts OfficialStoreProduct[]
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  REMOVED
}

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  categoryId  String
  title       String
  description String        @db.Text
  priceCents  Int
  currency    String        @default("USD")
  images      String[]      @default([])
  status      ListingStatus @default(PENDING)
  rejectionReason String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  seller   User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([status])
  @@index([categoryId])
  @@index([sellerId])
}

// Official store products (sold by the platform itself)
model OfficialStoreProduct {
  id          String   @id @default(cuid())
  categoryId  String
  title       String
  description String   @db.Text
  priceCents  Int
  currency    String   @default("USD")
  images      String[] @default([])
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@index([isActive])
}

// ----------------------------- ORDERS -----------------------------

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_ESCROW
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum OrderSource {
  MARKETPLACE
  OFFICIAL_STORE
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  source          OrderSource @default(MARKETPLACE)
  status          OrderStatus @default(PENDING_PAYMENT)
  subtotalCents   Int
  guaranteeFeeCents Int       @default(0)
  totalCents      Int
  currency        String      @default("USD")
  paymentMethod   String?     // key of PaymentMethodSetting
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  buyer            User              @relation("BuyerOrders", fields: [buyerId], references: [id])
  items            OrderItem[]
  payment          Payment?
  guaranteeRequest GuaranteeRequest?

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id                     String  @id @default(cuid())
  orderId                String
  listingId              String?
  officialStoreProductId String?
  quantity               Int     @default(1)
  unitPriceCents         Int
  titleSnapshot          String

  order        Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing      Listing?              @relation(fields: [listingId], references: [id])
  storeProduct OfficialStoreProduct? @relation(fields: [officialStoreProductId], references: [id])
}

// ----------------------------- PAYMENTS -----------------------------

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  provider      String        @default("placeholder") // stripe | paypal | manual ...
  providerRef   String?
  status        PaymentStatus @default(PENDING)
  amountCents   Int
  currency      String        @default("USD")
  rawPayload    Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Admin toggle for which payment methods are visible to buyers
model PaymentMethodSetting {
  id          String          @id @default(cuid())
  key         String          @unique // bank_transfer | card | wallet | manual_cash | stripe_card | paypal
  labelEn     String
  labelAr     String
  enabled     Boolean         @default(true)
  description String?         @db.Text
  sortOrder   Int             @default(0)
  provider    PaymentProvider @default(MANUAL)
  updatedAt   DateTime        @updatedAt
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  PAYMOB
  MANUAL
}

// ----------------------------- GUARANTEE / ESCROW -----------------------------

enum GuaranteeTier {
  BASIC
  PREMIUM
  FULL
}

enum GuaranteeRequestStatus {
  REQUESTED
  AWAITING_FUNDS
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  REJECTED
  DISPUTED
}

model GuaranteePackage {
  id          String        @id @default(cuid())
  tier        GuaranteeTier @unique
  nameEn      String
  nameAr      String
  feePercent  Int           // integer percent of order subtotal, e.g. 3
  minFeeCents Int           @default(0)
  features    String[]      @default([])
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  requests GuaranteeRequest[]
}

model GuaranteeRequest {
  id          String                @id @default(cuid())
  orderId     String                @unique
  packageId   String
  buyerId     String
  status      GuaranteeRequestStatus @default(REQUESTED)
  feeCents    Int
  notes       String?               @db.Text
  handledById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package GuaranteePackage @relation(fields: [packageId], references: [id])
  buyer   User             @relation(fields: [buyerId], references: [id])
}

// ----------------------------- REVIEWS / SUPPORT -----------------------------

model Review {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([authorId, targetId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id          String       @id @default(cuid())
  authorId    String
  assigneeId  String?
  subject     String
  body        String       @db.Text
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  author      User         @relation("TicketAuthor", fields: [authorId], references: [id])
  assignee    User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])
  messages    SupportTicketMessage[]

  @@index([status])
  @@index([authorId])
}

model SupportTicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String   @db.Text
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

// ----------------------------- AUDIT -----------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
}
